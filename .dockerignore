# Build output — never send to Docker build context
target/

# Version control
.git/
.gitignore
.gitattributes

# IDE and OS artefacts
.idea/
*.iml
.DS_Store
*.swp
*.swo

# Local environment overrides
.env
.env.*
*.local

# Logs
*.log
logs/

# Documentation (not needed in image)
docs/

# Test reports
target/surefire-reports/
target/site/

# Docker Compose files (not needed inside the image itself)
infra/docker/docker-compose.yml
